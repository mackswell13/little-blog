<div class="grid grid-cols-12 gap-2 mt-10">
  <div class="overflow-hidden col-span-4 col-start-2">
    <img
      src="/maxsherwin.jpg"
      alt="Max Sherwin Headshot"
      class="w-full aspect-[1/1] object-cover object-top rounded-full"
    />
  </div>
  <div
    class="
      text-headings text-6xl col-span-5 col-start-7 flex justify-center flex-col gap-8
    "
  >
    <h1 class="text-6xl font-lekton">Max Sherwin</h1>
    <h2 class="text-3xl font-lekton">Software Engineer</h2>
  </div>
</div>

<div class="mt-10">
  <h2 class="col-span-full page-heading">Blogs</h2>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    <% @blog_posts.each do |blog_post| %>
      <%= link_to blog_post, class: "bg-cards shadow-lg rounded-lg overflow-hidden transform hover:scale-105 transition-all duration-300" do %>
        <div class="p-4">
          <h2 class="text-2xl font-semibold text-primary mb-4"><%= blog_post.title %></h2>
          <div class="text-secondary text-sm line-clamp-3"><%= render_markdown blog_post.body %></div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
