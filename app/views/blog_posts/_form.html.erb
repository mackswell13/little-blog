<div class="max-w-4xl mx-auto mt-10 p-6 bg-white shadow-lg rounded-lg">
  <%= form_with model: blog_post, class: "space-y-6" do |form| %>
    <% if form.object.errors.any? %>
      <div class="bg-red-100 text-red-700 p-4 rounded-md">
        <h2 class="font-semibold mb-2">Errors:</h2>
        <ul class="list-disc list-inside text-sm">
          <% form.object.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, class: "block text-gray-700 font-medium mb-2" %>
      <%= form.text_field :title, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring focus:ring-blue-300 focus:border-blue-500" %>
    </div>

    <div>
      <%= form.label :body, class: "block text-gray-700 font-medium mb-2" %>
      <%= form.text_area :body, rows: 6, class: "w-full p-3 border border-gray-300 rounded-lg focus:ring focus:ring-blue-300 focus:border-blue-500" %>
    </div>

    <div class="text-center">
      <%= form.button "Create Blog Post",
        class: "bg-blue-600 text-white py-2 px-6 rounded-full text-lg hover:bg-blue-700 transition-all duration-200" %>
    </div>
  <% end %>
</div>

